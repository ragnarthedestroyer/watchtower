# Acki Watchtower environment template
# Copy this file to .env locally. Never commit real secrets.

# Runtime
WATCHTOWER_RUNTIME_MODE=demo
WATCHTOWER_SERVER_PORT=8787
WATCHTOWER_APP_URL=http://localhost:3000

# Public/read API endpoints
WATCHTOWER_GRAPHQL_ENDPOINT=
WATCHTOWER_REST_ENDPOINT=

# Future State V2 / app identity
WATCHTOWER_DAPP_ID=

# Telegram app/bot
WATCHTOWER_TELEGRAM_BOT_TOKEN=
WATCHTOWER_TELEGRAM_WEBAPP_URL=

# Database
WATCHTOWER_DATABASE_URL=

# Optional privileged infrastructure
WATCHTOWER_API_KEY=
WATCHTOWER_BLOCK_MANAGER_ENDPOINT=
